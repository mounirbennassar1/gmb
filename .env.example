# ── Database ──────────────────────────────────────────────────────
# Local Postgres:
#   postgresql://USER@localhost:5432/mahad_reviews
# Vercel + Neon (use the POOLED connection string for DATABASE_URL):
#   postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER@localhost:5432/mahad_reviews"

# ── Admin dashboard ───────────────────────────────────────────────
# Single shared password used to sign into /admin. Change it.
ADMIN_PASSWORD="change-me"

# Random secret used to sign the admin session cookie.
# Generate with:  openssl rand -hex 32
ADMIN_SESSION_SECRET="generate-a-long-random-value"
